#!name=Family Safe - Short Video Blocker
#!desc=Redirects TikTok, YouTube Shorts, and Facebook Reels to an info page.
#!author=FamilySafeTeam
#!homepage=https://github.com/familysafe/short-video-blocker
#!icon=https://raw.githubusercontent.com/familysafe/assets/main/icon.png

[URL Rewrite]
# Redirect TikTok-family domains to info page
^https?:\/\/([^\/]+\.)?(tiktok\.com|tiktokv\.com|tiktokcdn\.com|musical\.ly|muscdn\.com|snssdk\.com|amemv\.com|ibyteimg\.com)\/.* https://dieuphapam.net 302

# Redirect YouTube Shorts only
^https?:\/\/([^\/]+\.)?youtube\.com\/shorts\/.* https://dieuphapam.net 302

# Redirect Facebook Reels only
^https?:\/\/([^\/]+\.)?facebook\.com\/(reel|reels)\/.* https://dieuphapam.net 302
^https?:\/\/fb\.watch\/.* https://dieuphapam.net 302
